# LinkHop Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Django secret key - Generate a new one with:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-secure-secret-key-minimum-50-characters-long

# Allowed hosts - comma-separated list of domains
# Examples: localhost,linkhop.example.com,www.linkhop.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# CORE SETTINGS
# =============================================================================

# Debug mode - NEVER set to True in production
DEBUG=False

# Database URL
# SQLite: sqlite:///data/db.sqlite3
# PostgreSQL: postgres://user:password@host:port/database
DATABASE_URL=sqlite:///data/db.sqlite3

# Timezone
TIME_ZONE=UTC

# =============================================================================
# SECURITY SETTINGS (Production)
# =============================================================================

# Uncomment these for production HTTPS deployment:
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# =============================================================================
# LINKHOP SETTINGS
# =============================================================================

# Rate limiting
LINKHOP_API_SENDS_PER_MINUTE=30
LINKHOP_API_CONFIRMATIONS_PER_MINUTE=120
LINKHOP_API_REGISTRATIONS_PER_HOUR=10

# Message limits
LINKHOP_MESSAGE_URL_MAX_LENGTH=2048
LINKHOP_MESSAGE_TEXT_MAX_LENGTH=8000
LINKHOP_MESSAGE_RETENTION_DAYS=7

# SSE settings
LINKHOP_SSE_HEARTBEAT_SECONDS=30
LINKHOP_MAX_SSE_STREAMS_PER_DEVICE=5
LINKHOP_MAX_PENDING_MESSAGES=500

# Allow devices to send to themselves
LINKHOP_ALLOW_SELF_SEND=False

# Web Push (required for PWA push notifications)
# Generate VAPID keys and set these in your real .env, not in version control.
# LINKHOP_WEBPUSH_VAPID_PUBLIC_KEY=
# LINKHOP_WEBPUSH_VAPID_PRIVATE_KEY=
# LINKHOP_WEBPUSH_VAPID_SUBJECT=mailto:admin@example.com

# =============================================================================
# EMAIL SETTINGS (Optional)
# =============================================================================

# For error notifications (optional)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@linkhop.example.com
# SERVER_EMAIL=admin@linkhop.example.com

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=INFO

# =============================================================================
# DOCKER-SPECIFIC
# =============================================================================

# These are set automatically in Docker, but can be overridden:
# STATIC_ROOT=/app/staticfiles
# DJANGO_SETTINGS_MODULE=linkhop.settings.production

# PostgreSQL password (only needed if using PostgreSQL instead of SQLite)
# DB_PASSWORD=your-secure-db-password
