{
  "tasks": {
    "start": "deno run -A --watch src/main.ts",
    "check": "deno check src/main.ts",
    "fmt": "deno fmt",
    "test": "deno test -A tests/",
    "lint": "deno lint"
  },
  "imports": {
    "@db/sqlite": "jsr:@db/sqlite@0.13.0",
    "@hono/hono": "jsr:@hono/hono@4.12.9",
    "@std/dotenv": "jsr:@std/dotenv@0.225.6",
    "@std/path": "jsr:@std/path@1.1.4",
    "bcryptjs": "npm:bcryptjs@3.0.3",
    "web-push": "npm:web-push@3.6.7"
  },
  "fmt": {
    "semiColons": true,
    "singleQuote": true
  },
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    }
  }
}
