{
  "manifest_version": 2,
  "name": "LinkHop Lite",
  "version": "0.1.0",
  "description": "Keep your LinkHop Lite device online when the tab is closed",

  "permissions": [
    "tabs",
    "storage",
    "<all_urls>"
  ],

  "background": {
    "page": "background.html",
    "persistent": true
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "LinkHop Lite"
  }
}
