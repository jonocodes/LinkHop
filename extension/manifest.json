{
  "manifest_version": 2,
  "name": "LinkHop",
  "version": "0.1.0",
  "description": "Send and receive links between your devices via LinkHop",

  "permissions": [
    "storage",
    "notifications",
    "tabs",
    "contextMenus",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "LinkHop",
    "default_icon": {
      "48": "icons/icon-48.svg"
    }
  },

  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "linkhop@extension",
      "strict_min_version": "109.0"
    }
  }
}
